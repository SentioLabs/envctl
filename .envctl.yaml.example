# Example envctl configuration
# Copy this to .envctl.yaml and customize for your project
#
# See: https://github.com/sentiolabs/envctl

version: 1

# Default environment when -e/--env not specified
default_environment: dev

# ==============================================================================
# Global Backend Defaults (optional)
# ==============================================================================
# The presence of an 'aws' or '1pass' block determines the default backend.
# Environment-level blocks override the global default.

# AWS Secrets Manager (global defaults for all AWS environments):
aws:
  region: us-east-1
  # profile: my-profile  # Optional: use specific AWS profile

# 1Password (uncomment to use as global default instead of aws):
# 1pass:
#   vault: Development
#   account: my-account  # Optional: for multi-account setups

# ==============================================================================
# Environments
# ==============================================================================
# Each environment can override the global backend by specifying its own
# 'aws' or '1pass' block. If neither is present, inherits the global default.

environments:
  dev:
    secret: myapp/dev
    # Inherits global aws backend (no override needed)

  local:
    secret: My App Local Secrets
    1pass:                       # Override: use 1Password for local dev
      vault: Development

  staging:
    secret: myapp/staging
    aws:                         # Explicit AWS with custom region
      region: us-west-2
      profile: staging

  prod:
    secret: myapp/prod
    # Inherits global aws backend

# ==============================================================================
# Common Configuration (works with all backends)
# ==============================================================================

# Optional: Include all keys from primary secret (default: false)
# include_all: true

# Optional: Additional secrets to include in all environments
include:
  # Pull all keys from a shared secret (requires include_all: true)
  - secret: shared/datadog

  # Pull specific key and rename it
  - secret: shared/stripe
    key: test_key
    as: STRIPE_SECRET_KEY

  # Pull specific key, keep original name
  - secret: shared/sendgrid
    key: API_KEY

# Optional: Explicit env var mappings using secret#key syntax
# These take precedence over automatic loading
mapping:
  DATABASE_URL: myapp/dev#database_url
  REDIS_URL: myapp/dev#redis_url
